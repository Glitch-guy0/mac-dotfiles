// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "relative_line_numbers": "disabled",
  "soft_wrap": "bounded",
  "show_wrap_guides": true,
  "preferred_line_length": 130,
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "format_on_save": "off",
  "diff_view_style": "unified",
  "collaboration_panel": {
    "dock": "right"
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "opencode": {
      "type": "extension",
      "favorite_models": [
        "opencode/big-pickle",
        "opencode/big-pickle/high",
        "opencode/big-pickle/max",
        "opencode/minimax-m2.5-free"
      ]
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "kilo": {
      "default_mode": "ask",
      "favorite_models": [
        "kilo/minimax/minimax-m2.5:free",
        "kilo/giga-potato-thinking",
        "kilo/giga-potato",
        "kilo/kilo-auto/free",
        "kilo/openrouter/free",
        "kilo/corethink:free",
        "kilo/nvidia/nemotron-3-super-120b-a12b:free",
        "kilo/x-ai/grok-code-fast-1:optimized:free"
      ],
      "type": "registry"
    }
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "openrouter",
      "model": "openrouter/free",
      "enable_thinking": false
    },
    "flexible": true,
    "default_profile": "ask",
    "profiles": {
      "ask": {
        "name": "ask",
        "tools": {
          "terminal": true,
          "save_file": true,
          "restore_file_from_disk": true,
          "read_file": true,
          "open": true,
          "now": true,
          "list_directory": true,
          "grep": true,
          "find_path": true,
          "fetch": true,
          "edit_file": false,
          "diagnostics": true,
          "delete_path": false,
          "create_directory": false,
          "copy_path": true
        },
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "dock": "left",
    "default_model": {
      "provider": "openrouter",
      "model": "openai/gpt-oss-20b:free",
      "enable_thinking": true
    },
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "google/gemma-3-4b-it:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "z-ai/glm-4.5-air:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "arcee-ai/trinity-mini:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "openrouter/free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "arcee-ai/trinity-large-preview:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "nvidia/nemotron-3-super-120b-a12b:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "nvidia/nemotron-nano-9b-v2:free",
        "enable_thinking": false
      },
      {
        "provider": "openrouter",
        "model": "google/gemma-4-31b-it:free",
        "enable_thinking": true
      }
    ],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left",
    "sort_by_path": false,
    "tree_view": false
  },
  "show_edit_predictions": false,
  "languages": {
    "TypeScript": {
      "show_edit_predictions": false
    }
  },
  "icon_theme": "Catppuccin Latte",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Macchiato"
  },
  "terminal": {
    "dock": "bottom",
    "font_family": "FiraCode Nerd Font Mono"
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  }
}
